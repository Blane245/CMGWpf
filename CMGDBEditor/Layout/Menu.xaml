<UserControl x:Class="CMGDBEditor.Layout.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGDBEditor.Layout"
             xmlns:viewmodel="clr-namespace:CMGDBEditor.View" 
             d:DataContext="{d:DesignInstance Type=viewmodel:MainView}"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid Background="Transparent">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0">
            <Button Command="{Binding ShowEnsembleCommand}" >Ensembles</Button>
            <Button Command="{Binding ShowNoteSequencesCommand}" >Note Sequences</Button>
            <Button Command="{Binding ShowHelpCommand}" >Help</Button>
        </StackPanel>
    </Grid>
</UserControl>
