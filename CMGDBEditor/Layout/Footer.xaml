<UserControl x:Class="CMGDBEditor.Layout.Footer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGDBEditor.Layout"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainView}"
             xmlns:viewmodel="clr-namespace:CMGDBEditor.View"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <Grid>
        <TextBlock Text="{Binding Status.Text}" FontWeight="Bold" Background="White" Foreground="{Binding Status.Brush}"/>
    </Grid>
</UserControl>
