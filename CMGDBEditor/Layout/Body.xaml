<UserControl x:Class="CMGDBEditor.Layout.Body"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGDBEditor.Layout"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainView}"
             xmlns:viewmodel="clr-namespace:CMGDBEditor.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Padding="0">
            <ContentControl x:Name="ElementPanel" Content="{Binding ElementPanel}" />
        </Border>

    </Grid>
</UserControl>
