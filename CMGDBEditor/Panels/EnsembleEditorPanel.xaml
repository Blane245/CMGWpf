<UserControl x:Class="CMGDBEditor.Panels.EnsembleEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGDBEditor.Panels"
             d:DataContext="{d:DesignInstance Type=viewmodel:EnsembleView}"
             xmlns:viewmodel="clr-namespace:CMGDBEditor.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- This panel, displayed in the middle of the body appears when a ensemble is selected for edit. All properties can be changed, including the name, description, and the list of associated voices in a modifiable data grid. -->
    <UserControl.Resources>
        <DataTemplate x:Key="Select">
            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding Path=IsVoiceSelected, Mode=TwoWay}"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <StackPanel Orientation="Vertical">
            <Label Content="{Binding EnsembleEditorTitle}" FontSize="16"/>
            <StackPanel Orientation="Horizontal">
                <Label Content="Name: "/>
                <TextBox Text="{Binding NewEnsembleName}" ToolTip="Enter the name of the ensemble" MinWidth="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Description: "/>
                <TextBox Text="{Binding UIEnsemble.Description}" ToolTip="Enter the description of the ensemble" MinWidth="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">

                <Label Content="Voices: " VerticalAlignment="Top"/>
                <ScrollViewer MaxHeight="500">
                    <ListView ItemsSource="{Binding SelectableVoiceList}">
                        <ListView.View>
                            <GridView ColumnHeaderToolTip="Select the voices that are to be included in the ensemble.">
                                <GridViewColumn CellTemplate="{StaticResource Select}" Header="Select"/>
                                <GridViewColumn DisplayMemberBinding="{Binding Path=Voice.Name, Mode=TwoWay}" Header="Voice"/>
                                <GridViewColumn DisplayMemberBinding="{Binding Path=Voice.Description, Mode=TwoWay}" Header="Description"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </StackPanel>
            <Border BorderBrush="LightGray" BorderThickness="1"></Border>
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SubmitEnsembleCommand}" Content="Submit" ToolTip="Submit the ensemble changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
                <Button Command="{Binding CancelEditorCommand}" Content="Cancel" ToolTip="Cancel ensemble changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
