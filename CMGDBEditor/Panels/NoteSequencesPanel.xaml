<UserControl x:Class="CMGDBEditor.Panels.NoteSequencesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGDBEditor.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- This panel is for managing note sequences and tags. The left side of the panel is for managing note sequences, which includes a list of existing note sequences with their names and descriptions, and a button to add a new note sequence. Left click on the note sequence will display the sequence editor in the middle of the panel which shows the details of the selected note sequence, including its name, description, and a list of tags associated with the note sequence in a data grid. Right click on the sequence will perform delete. The tags can be added or removed from the note sequence. The tag list on the right side will show all available tags in the database, and the tags that are currently associated with the a note sequence will be highlighted. Tags may be added with an Add Tag button and deleted by right clicking on the tag. When a tag is selected (left click), a list of associated Note sequences is displayed then selecting one from the list will display the note sequence editor. Right click on a tag will perform delete.
    -->
    <Grid>
        <Grid.ColumnDefinitions>
        <ColumnDefinition Width="100"/>
        <!-- note sequence list -->
        <ColumnDefinition Width="auto"/>
        <!-- note sequence edit area -->
        <ColumnDefinition Width="100"/>
        <!-- tag list -->
    </Grid.ColumnDefinitions>
    <StackPanel Grid.Column="0">
        <Label>Note Sequences</Label>
        <Button Command="{Binding AddNoteSequenceCommand}">Add</Button>
        <!-- adds a new note sequence by means of the note sequence editor, then refreshes the note sequence list -->
        <ItemsControl>
            <!-- list of existing note sequences -->
        </ItemsControl>
    </StackPanel>
    <StackPanel Grid.Column="1">
        <ContentControl Content="{Binding ElementName=EditorPanel}"/>
        <!-- note sequence edit area -->
    </StackPanel>
    <StackPanel Grid.Column="2">
        <Label>Tags</Label>
        <Button Command="{Binding AddTagCommand}">Add</Button>
        <!-- adds a new tag by means of the tag editor, then refreshes the tag list -->
        <ItemsControl>
            <!-- list of existing tags -->
        </ItemsControl>
    </StackPanel>
    </Grid>
</UserControl>
