<UserControl x:Class="CMGDBEditor.Panels.EnsemblePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGDBEditor.Panels"
             d:DataContext="{d:DesignInstance Type=viewmodel:EnsembleView}"
             xmlns:viewmodel="clr-namespace:CMGDBEditor.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1800"
             Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>

        <!-- Ensembles Column -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <StackPanel Margin="5">
                <Label FontWeight="Bold" FontSize="14" Content="Ensembles" HorizontalAlignment="Center"/>
                <Button Command="{Binding AddEnsembleCommand}" Margin="0" Padding="0" Width="100">Add Ensemble</Button>
                    <DataGrid ItemsSource="{Binding EnsembleList}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="500">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" CanUserReorder="True" CanUserResize="True" CanUserSort="True"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" CanUserReorder="True" CanUserResize="True" CanUserSort="True"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit" 
                                          Command="{Binding DataContext.EditEnsembleCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Delete" 
                                          Command="{Binding DataContext.DeleteEnsembleCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
            </StackPanel>
        </Border>

        <!-- Voices Column -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5" >
            <StackPanel Margin="5">
                <Label FontWeight="Bold" FontSize="14" Content="Voices" HorizontalAlignment="Center"/>
                <Button Command="{Binding AddVoiceCommand}" Margin="0" Padding="0" Width="100">Add Voice</Button>
                <DataGrid ItemsSource="{Binding VoiceList}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="500">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" CanUserResize="True" CanUserReorder="True" CanUserSort="True"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" CanUserResize="True" CanUserReorder="True" CanUserSort="True"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit"                                           Command="{Binding DataContext.EditVoiceCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="List Ensembles"                                           Command="{Binding DataContext.ListVoiceEnsemblesCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Delete"                                           Command="{Binding DataContext.DeleteVoiceCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
            </StackPanel>
        </Border>
        <ContentControl Grid.Column="2" Content="{Binding EditorPanel}"/>
    </Grid>
</UserControl>
