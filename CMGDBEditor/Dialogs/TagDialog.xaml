<Window x:Class="CMGDBEditor.Dialogs.TagDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGDBEditor.Dialogs"
             xmlns:panels="clr-namespace:CMGWpf.Panels;assembly=CMGWpf"
        d:DataContext="{d:DesignInstance Type=viewmodel:NoteSequencesView}"
        xmlns:viewmodel="clr-namespace:CMGDBEditor.View"
        mc:Ignorable="d" Width="300" Height="400">
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Label Content="Name: "  VerticalAlignment="Top"/>
                <TextBox Text="{Binding NewTagName}" VerticalAlignment="Top" MinWidth="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5,5,0,0">
                <Button Content="OK" Command="{Binding SubmitTagCommand}" VerticalAlignment="Top"/>
                <Button Content="Cancel" Click="Button_Click"/>
            </StackPanel>
            <panels:MessagePanel Source="{Binding DataContext.Errors, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,5,0,5" MinHeight="200"/>

        </StackPanel>
    </Grid>
</Window>
