<Window x:Class="CMGDBEditor.Dialogs.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGDBEditor.Dialogs"
        xmlns:panels="clr-namespace:CMGWpf.Panels;assembly=CMGWpf"
        xmlns:properties="clr-namespace:CMGDBEditor.Properties"
        xmlns:services="clr-namespace:CMGWpf.Services;assembly=CMGWpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:viewmodel="clr-namespace:CMGDBEditor.View"
        Icon="/CMGWpf;component/Assets/CMG-Logo.ico"
        mc:Ignorable="d"
        WindowStyle="None"
                ResizeMode="CanResize"
        Title="HelpDialog">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <!-- Custom Window Chrome -->
                <RowDefinition Height="{Binding Source={x:Static services:SizeService.Instance}, Path=ChromeHeight}"/>
                <!-- This probably is wrong as a resize of the CMG window will affect this one and vice versa -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Window Chrome with Menu -->
            <panels:CustomWindowChrome 
            Grid.Row="0" 
            WindowTitle="{Binding Source={x:Static viewmodel:MainView.Instance},Path=WindowTitle}"
            IconSource="/CMGWpf;component/Assets/CMG-Logo.ico"
        >
            </panels:CustomWindowChrome>
            <Border  Grid.Row="1" BorderThickness="1" BorderBrush="Black">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Application Name -->
                    <TextBlock Text="CMG Database Editor" 
                               FontSize="24" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <!-- Subtitle -->
                    <TextBlock Text="Database Editor for the Computer Music Generator" 
                               FontSize="16"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               Foreground="Gray"
                               Margin="0,0,0,20"/>

                    <!-- Version -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Version " FontWeight="Bold"/>
                        <TextBlock Text="{Binding Source={x:Static properties:Settings.Default}, Path=Version}"/>
                    </StackPanel>

                    <!-- Description -->
                    <TextBlock TextWrapping="Wrap" 
                               Margin="0,0,0,20"
                               TextAlignment="Center">
                        A Editor for Ensembles and Note Sequences that are used by the CMG. 
                    </TextBlock>

                    <Separator Margin="0,0,0,20"/>

                    <!-- Author Information -->
                    <TextBlock Text="Author" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel Margin="20,0,0,20">
                        <TextBlock Text="Bob Lane" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="GitHub: "/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/Blane245" RequestNavigate="Hyperlink_RequestNavigate">
                                    github.com/Blane245
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Repository: "/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/Blane245/CMGWpf" RequestNavigate="Hyperlink_RequestNavigate">
                                    github.com/Blane245/CMGWpf
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Separator Margin="0,0,0,20"/>

                    <!-- Key Technologies -->
                    <TextBlock Text="Built With" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel Margin="20,0,0,20">
                        <TextBlock Text="• .NET 10.0 / WPF" Margin="0,0,0,3"/>
                        <TextBlock Text="• Pomelo Entity Framework for MySql" Margin="0,0,0,3"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,20"/>

                    <!-- Copyright -->
                    <TextBlock TextWrapping="Wrap" 
                               HorizontalAlignment="Center"
                               FontSize="11"
                               Foreground="Gray"
                               Margin="0,0,0,20">
                        <Run Text="© 2026 Bob Lane. All rights reserved."/>
                    </TextBlock>

                    <!-- Close Button -->
                    <Button Content="Close" 
                            Width="100" 
                            Height="30"
                            Click="Close_Click"
                            HorizontalAlignment="Center"
                            IsDefault="True"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>
