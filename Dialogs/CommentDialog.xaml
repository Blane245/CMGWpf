<Window x:Class="CMGWpf.Dialogs.CommentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        d:DataContext="{d:DesignInstance Type=viewmodel:FileViewModel}"
        mc:Ignorable="d"
        Title="Edit File Comment" Height="450" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <TextBox Height="350" Width="700" 
                 Text="{Binding NewComment}" 
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalAlignment="Center" 
                 VerticalAlignment="Center"/>
        <Button x:Name="OK" Width="40" Height="20" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10" Content="OK"
                Command="{Binding EditCommentOkCommand}"
                />
        <Button x:Name="Cancel" Width="40" Height="20" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="60,0,0,10" Content="Cancel"
                Command="{Binding EditCommentCancelCommand}"
                
                />

    </Grid>
</Window>
