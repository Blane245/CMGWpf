<Window x:Class="CMGWpf.Dialogs.ViewSequence"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:model="clr-namespace:CMGWpf.Model"
        d:DataContext="{d:DesignInstance Type=model:Sequencer}"
        mc:Ignorable="d"
        Title="View Sequence Items"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="White"
        SizeToContent="Width"
        WindowStartupLocation="CenterOwner"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Label Content="Sequence:" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Label Content="{Binding Name, StringFormat='Sequence: {0}'}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header Row -->
                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Note" Width="100" FontWeight="Bold"/>
                    <TextBlock Text="Beats" Width="100" FontWeight="Bold"/>
                </StackPanel>
                <!-- Data Rows -->
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                <TextBlock Text="{Binding Value}" Width="100"/>
                                <TextBlock Text="{Binding Beats}" Width="100"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="2" Content="Close" Width="40" HorizontalAlignment="Left" Margin="5,0,0,0" Click="Close" />
    </Grid>
</Window>
