<Window x:Class="CMGWpf.Dialogs.ViewSequence"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:model="clr-namespace:CMGWpf.Model"
        d:DataContext="{d:DesignInstance Type=model:Sequence}"
        mc:Ignorable="d"
        Title="View Sequence Items"
        WindowStyle="None"
        Background="White"
        WindowStartupLocation="CenterOwner"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
        <Label Content="{Binding Name, StringFormat='Sequence: {0}'}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DataGrid
            ItemsSource="{Binding Items}"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            IsReadOnly="True"
            >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Note" Binding="{Binding value}"/>
                    <DataGridTextColumn Header="Beats" Binding="{Binding beats}"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
        <Button Grid.Row="2" Content="Close" Width="40" HorizontalAlignment="Left" Margin="5,0,0,0" Click="Close" />
    </Grid>
</Window>
