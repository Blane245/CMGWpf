<Window x:Class="CMGWpf.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        xmlns:properties="clr-namespace:CMGWpf.Properties"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="600" Height="500"
        Title="About CMG"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        >
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="0"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Chrome -->
        <panels:CustomWindowChrome Grid.Row="0"
                                     WindowTitle="About CMG"
                                     ChromeBackground="SaddleBrown">
        </panels:CustomWindowChrome>

        <!-- Main Content -->
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Logo -->
                    <Image Source="/Assets/CMG-Logo.png" 
                           Width="128" Height="128" 
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                    <!-- Application Name -->
                    <TextBlock Text="CMG" 
                               FontSize="24" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <!-- Subtitle -->
                    <TextBlock Text="Computer Music Generator" 
                               FontSize="16"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               Foreground="Gray"
                               Margin="0,0,0,20"/>

                    <!-- Version -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Version " FontWeight="Bold"/>
                        <TextBlock Text="{Binding Source={x:Static properties:Settings.Default}, Path=Version}"/>
                    </StackPanel>

                    <!-- Description -->
                    <TextBlock TextWrapping="Wrap" 
                               Margin="0,0,0,20"
                               TextAlignment="Center">
                        A powerful Windows-based desktop application for algorithmic and stochastic music composition, 
                        audio synthesis, and multimedia generation.
                    </TextBlock>

                    <Separator Margin="0,0,0,20"/>

                    <!-- Author Information -->
                    <TextBlock Text="Author" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel Margin="20,0,0,20">
                        <TextBlock Text="Bob Lane" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="GitHub: "/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/Blane245" RequestNavigate="Hyperlink_RequestNavigate">
                                    github.com/Blane245
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Repository: "/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/Blane245/CMGWpf" RequestNavigate="Hyperlink_RequestNavigate">
                                    github.com/Blane245/CMGWpf
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Separator Margin="0,0,0,20"/>

                    <!-- Inspiration -->
                    <TextBlock Text="Inspiration" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock TextWrapping="Wrap" Margin="20,0,0,20">
                        Inspired by "Formalized Music: Thought and Mathematics in Composition" by Iannis Xenakis, 
                        this application implements stochastic and algorithmic music composition techniques 
                        combined with modern digital signal processing.
                    </TextBlock>

                    <Separator Margin="0,0,0,20"/>

                    <!-- Key Technologies -->
                    <TextBlock Text="Built With" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel Margin="20,0,0,20">
                        <TextBlock Text="• .NET 10.0 / WPF" Margin="0,0,0,3"/>
                        <TextBlock Text="• NAudio - Audio playback and recording" Margin="0,0,0,3"/>
                        <TextBlock Text="• FFMpegCore - Video generation" Margin="0,0,0,3"/>
                        <TextBlock Text="• Material.Icons.WPF - Modern UI icons" Margin="0,0,0,3"/>
                        <TextBlock Text="• SoundFont 2.0 - Instrument synthesis" Margin="0,0,0,3"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,20"/>

                    <!-- Copyright -->
                    <TextBlock TextWrapping="Wrap" 
                               HorizontalAlignment="Center"
                               FontSize="11"
                               Foreground="Gray"
                               Margin="0,0,0,20">
                        <Run Text="© 2026 Bob Lane. All rights reserved."/>
                    </TextBlock>

                    <!-- Close Button -->
                    <Button Content="Close" 
                            Width="100" 
                            Height="30"
                            Click="Close_Click"
                            HorizontalAlignment="Center"
                            IsDefault="True"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
