<Window x:Class="CMGWpf.Dialogs.MoveCopyGeneratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        d:DataContext="{d:DesignInstance Type=viewmodel:GeneratorViewModel}"
        mc:Ignorable="d"
        WindowStyle="None"
        Background="White"
        ResizeMode="CanResize"
        Title="MoveCopyGeneratorDialog" >
    <Grid>
        <StackPanel Orientation="Vertical">
            <Border Height="25" VerticalAlignment="Top" Background="LightBlue">
                <StackPanel Orientation="Horizontal" Height="30">
                    <Label Content="{Binding MoveCopyMode}" Foreground="Black" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                    <Label Content="Generator" Foreground="Black" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0"/>
                    <Button x:Name="CloseDialog" Width="20" Height="15" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5" Content="X" FontSize="12" Command="{Binding GeneratorCancelCommand}"/>
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label Content="Select Track:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Tracks}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedTrack}" Width="150" Margin="5"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <Button x:Name="MoveCopyButton" Content="OK" Width="75" Margin="5" Command="{Binding MoveCopyCommand}"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="75" Margin="5" Command="{Binding GeneratorCancelCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
