<Window x:Class="CMGWpf.Dialogs.MoveCopyGeneratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        d:DataContext="{d:DesignInstance Type=viewmodel:GeneratorViewModel}"
        mc:Ignorable="d"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None"
        ResizeMode="CanResize"
        Width="300" Height="100"
        Icon="/Assets/CMG-Logo.ico"
                Background="White"

        >
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="5"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <panels:CustomWindowChrome Grid.Row="0"
                                     WindowTitle="{Binding MoveCopyTitle}"
                                   ChromeBackground="DarkCyan"
                                    >
        </panels:CustomWindowChrome>
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Padding="5">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Target Track :" VerticalAlignment="Center" Margin="0"/>
                    <ComboBox ItemsSource="{Binding Tracks}" SelectedItem="{Binding SelectedTrack}" Width="150" ToolTip="Selct the track to receive the moved or copied generator."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Width="50" Content="OK" Command="{Binding MoveCopyCommand}" Margin="0"/>
                    <Button Width="50" Content="Cancel" Click="Cancel_Click" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
