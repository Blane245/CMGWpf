<Window x:Class="CMGWpf.Dialogs.PreferencesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:CMGWpf.Dialogs"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        xmlns:viewmodel="clr-namespace:CMGWpf.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        d:DataContext="{d:DesignInstance Type=viewmodel:GlobalService}"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="210" Width="400"
        Icon="/Assets/CMG-Logo.ico"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        >
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="5"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <panels:CustomWindowChrome Grid.Row="0"
                                     WindowTitle="Edit Preferences"
                                     ChromeBackground="SaddleBrown">
        </panels:CustomWindowChrome>
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Padding="5">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Soundfont Directory: "/>
                    <TextBox Text="{Binding SoundFontFileLocation, Mode=TwoWay}" ToolTip="Enter the local computer file system path to the folder that contains soundfont files."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Record Format: "/>
                    <ComboBox ItemsSource="{Binding RecordFormats}" SelectedItem="{Binding RecordFormat, Mode=TwoWay}" ToolTip="Select the desired audio recording format."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Snap Mode: "/>
                    <CheckBox IsChecked="{Binding IsSnap, Mode=TwoWay}" ToolTip="Snap when moving start or end time of generator"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Snap Increment (sec): "/>
                    <xctk:DoubleUpDown Value="{Binding SnapIncrement, Mode=TwoWay}" Minimum="0.1" Maximum="1000" Increment="0.1" ToolTip="The number of seconds between snap points"/>
                </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="OK" Width="50" Content="OK" Command="{Binding EditPreferencesOkCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Margin="0"/>
                    <Button x:Name="Cancel" Width="50" Content="Cancel" Click="Cancel_Click" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
