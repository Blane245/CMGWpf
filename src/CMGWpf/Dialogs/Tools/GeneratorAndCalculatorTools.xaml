<Window x:Class="CMGWpf.Dialogs.Tools.GeneratorAndCalculatorTools"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        xmlns:toolspanels="clr-namespace:CMGWpf.Panels.Tools"
        xmlns:services="clr-namespace:CMGWpf.Services"
        xmlns:layout="clr-namespace:CMGWpf.Layout"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        d:DesignHeight="450" d:DesignWidth="800"
>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="5"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- Custom Window Chrome with Menu -->
        <panels:CustomWindowChrome Grid.Row="0"
                                   ChromeBackground="LightSkyBlue"
                                     WindowTitle="CMG Tools"
                                   />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="black" BorderThickness="1">
                <StackPanel Orientation="Vertical">
                    <Label Content="Midi/Frequency Converter"/>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal">
                            <Label Content="Midi Number [0-127] (cents): "/>
                            <xctk:DoubleUpDown Value="{Binding Midi1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="127" Increment="0.01" Width="70" ToolTip="Enter this value to calculate the equivalent audio frequency."/>
                            <Label Content="Audio Frequency [8-22000] {Hz): "/>
                            <Label Content="{Binding Frequency1}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <xctk:DoubleUpDown Value="{Binding Frequency2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="8" Maximum="22000" Increment="0.001" Width="100" ToolTip="Enter this value to calculate the equivalent midi number. "/>
                            <Label Content="Midi Number [0-127] (cents): "/>
                            <Label Content="{Binding Midi2}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1"  BorderBrush="black" BorderThickness="1">
                <StackPanel Orientation="Vertical">
                    <Label Content="Oscillator Frequency Calculator"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Amplitude (attribute units): "/>
                        <xctk:DoubleUpDown Value="{Binding Amplitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="100" Increment="0.01" Width="70" ToolTip="The amplitude of the attribute."/>
                        <Label Content="Beats/Minute [1,1000]: "/>
                        <xctk:DoubleUpDown Value="{Binding BPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="1000" Increment="0.01" Width="100" ToolTip="The beats per minute, usually taken from the speed attribute. "/>
                        <Label Content="Frequency to hit all values (mHz): "/>
                        <Label Content="{Binding OscillatorFrequency}" Width="100"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"  BorderBrush="black" BorderThickness="1">
                <StackPanel Orientation="Vertical">
                    <Label Content="Measure Duration Calculator"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Number of Beats [1,100]: "/>
                        <xctk:DoubleUpDown Value="{Binding BeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="100" Increment="1" Width="70" ToolTip="The number of beats in a measure"/>
                        <Label Content="Beats/Minute [1,1000]: "/>
                        <xctk:DoubleUpDown Value="{Binding MeasureBPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="1000" Increment="0.01" Width="100" ToolTip="The beats per minute"/>
                        <Label Content="Measure Duration (sec): "/>
                        <Label Content="{Binding MeasureDuration}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" BorderBrush="black" BorderThickness="1">
                <toolspanels:GeneratorsEqualPanel/>
            </Border>
        </Grid>
        <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
            <Border Grid.Column="0"  BorderBrush="black" BorderThickness="1">
                    <toolspanels:GeneratorsAlignPanel/>
                </Border>
            <Border Grid.Column="1"  BorderBrush="black" BorderThickness="1">
                    <toolspanels:GeneratorsStaggerPanel/>
                </Border>
            </Grid>
        <Grid Grid.Row="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" FontWeight="Bold" Background="White" Foreground="{Binding Brush}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
