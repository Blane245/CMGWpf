<Window x:Class="CMGWpf.Dialogs.Tools.MeasureDurationCalculatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs.Tools"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        d:DataContext="{d:DesignInstance Type=viewmodel:ToolsViewModel}"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
                ResizeMode="CanResize"
        Width="750" Height="100"
        Background="White"

        >
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="5"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <panels:CustomWindowChrome Grid.Row="0"
                                     WindowTitle="Measure Duration Calculator"
                                   ChromeBackground="DarkCyan"
                                    >
        </panels:CustomWindowChrome>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Label Content="Number of Beats [1,100]: "/>
            <xctk:DoubleUpDown Value="{Binding BeatCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="100" Increment="1" Width="70" ToolTip="The number of beats in a measure"/>
            <Label Content="Beats/Minute [1,1000]: "/>
            <xctk:DoubleUpDown Value="{Binding MeasureBPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="1000" Increment="0.01" Width="100" ToolTip="The beats per minute"/>
            <Label Content="Measure Duration (sec): "/>
            <Label Content="{Binding MeasureDuration}"/>
        </StackPanel>
    </Grid>
</Window>
