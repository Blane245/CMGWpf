<Window x:Class="CMGWpf.Dialogs.Tools.NoteSequenceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs.Tools"
        Title="NoteSeqeunceDialog" Height="450" Width="800"
                xmlns:panels="clr-namespace:CMGWpf.Panels"
        xmlns:toolspanels="clr-namespace:CMGWpf.Panels.Tools"
        xmlns:services="clr-namespace:CMGWpf.Services"
        xmlns:layout="clr-namespace:CMGWpf.Layout"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        d:DesignHeight="450" d:DesignWidth="800"
>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="5"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>
        <panels:CustomWindowChrome Grid.Row="0"
                                   ChromeBackground="HotPink"
                                     WindowTitle="CMG Ensemble and Voice Editor"
                                   />

        <Grid Grid.Row="1" MinHeight="400">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1">
                <StackPanel Margin="5">
                    <Label FontWeight="Bold" FontSize="14" Content="Ensembles" HorizontalAlignment="Center"/>
                    <Button Command="{Binding AddNoteSequenceCommand}" Margin="0" Padding="0" Width="100">Add Note Sequence</Button>
                    <DataGrid ItemsSource="{Binding NoteSequenceList}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="500">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" CanUserReorder="True" CanUserResize="True" CanUserSort="True"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" CanUserReorder="True" CanUserResize="True" CanUserSort="True"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit" 
                                          Command="{Binding DataContext.EditNoteSequenceCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Delete" 
                                          Command="{Binding DataContext.DeleteNoteSequenceCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="0" >
                <StackPanel Margin="5">
                    <Label FontWeight="Bold" FontSize="14" Content="Voices" HorizontalAlignment="Center"/>
                    <Button Command="{Binding AddTagCommand}" Margin="0" Padding="0" Width="100">Add Tag</Button>
                    <DataGrid ItemsSource="{Binding TagList}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="500">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" CanUserResize="True" CanUserReorder="True" CanUserSort="True"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit"                                           Command="{Binding DataContext.EditTagCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="List Note Sequences"                                           Command="{Binding DataContext.ListTagVoiceSequencesCommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Delete"                                           Command="{Binding DataContext.DeleteTagommand, 
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem, 
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </StackPanel>
            </Border>
            <ContentControl Grid.Column="2" Content="{Binding EditorPanel}"/>
        </Grid>
        <Grid Grid.Row="3">
            <panels:MessagePanel Source="{Binding DataContext.Errors, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="0" MinHeight="150"/>
        </Grid>
    </Grid>
</Window>
