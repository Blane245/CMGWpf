<Window x:Class="CMGWpf.Dialogs.Tools.MidiFrequencyConverterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs.Tools"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        d:DataContext="{d:DesignInstance Type=viewmodel:ToolsViewModel}"
        mc:Ignorable="d"
        WindowStyle="ToolWindow"
        Background="White"
        WindowStartupLocation="CenterOwner"
        Title="Midi Frequency Converter" Height="90" Width="400"
        >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Label Content="Midi [0,127]"/>
                <xctk:DoubleUpDown Value="{Binding Midi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="127" Increment="0.01" Width="70" ToolTip="Enter a value and the frequency of the midi number will be calculated."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Frequency [1,20,000 Hz]"/>
                <xctk:DoubleUpDown Value="{Binding Frequency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="20000" Increment="0.01" Width="100" ToolTip="Enter a value and the midi number of the frequency will be calculated"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
