<Window x:Class="CMGWpf.Dialogs.Tools.MidiFrequencyConverterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CMGWpf.Dialogs.Tools"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        d:DataContext="{d:DesignInstance Type=viewmodel:ToolsViewModel}"
        mc:Ignorable="d"
                WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Width="350" Height="100"
        Background="White"

        >
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="5"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <panels:CustomWindowChrome Grid.Row="0"
                                     WindowTitle="Midi&lt;-&gt;Frequency converter"
                                   ChromeBackground="DarkCyan"
                                    >
        </panels:CustomWindowChrome>
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Padding="5">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Midi [0,127]: "/>
                    <xctk:DoubleUpDown Value="{Binding Midi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="127" Increment="0.01" Width="70" ToolTip="Enter a value and the frequency of the midi number will be calculated."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Frequency [1,20,000 Hz]: "/>
                    <xctk:DoubleUpDown Value="{Binding Frequency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="1" Maximum="20000" Increment="0.01" Width="100" ToolTip="Enter a value and the midi number of the frequency will be calculated"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
