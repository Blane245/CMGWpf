<UserControl x:Class="CMGWpf.Panels.MessagePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             d:DataContext="{d:DesignInstance Type=viewmodel:FileViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800"
             >
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
            <ItemsControl ItemsSource="{Binding Source, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" FontWeight="Bold" Background="White" Foreground="{Binding Brush}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
