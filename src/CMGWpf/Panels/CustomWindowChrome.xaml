<UserControl x:Class="CMGWpf.Panels.CustomWindowChrome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels"
             mc:Ignorable="d" 
             Height="40"
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid Background="{Binding ChromeBackground, RelativeSource={RelativeSource AncestorType=local:CustomWindowChrome}}"
          MouseLeftButtonDown="DragArea_MouseLeftButtonDown"
          MouseMove="DragArea_MouseMove">
        <Grid.ColumnDefinitions>
            <!-- Logo -->
            <ColumnDefinition Width="Auto"/>
            <!-- Menu (optional) -->
            <ColumnDefinition Width="Auto"/>
            <!-- Spacer -->
            <ColumnDefinition Width="*"/>
            <!-- Title -->
            <ColumnDefinition Width="Auto"/>
            <!-- Spacer -->
            <ColumnDefinition Width="*"/>
            <!-- Window Controls -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Logo -->
        <Image Grid.Column="0" 
               Source="{Binding IconSource, RelativeSource={RelativeSource AncestorType=local:CustomWindowChrome}}"
               Width="32" 
               Height="32"
               Margin="8,4,8,4"
               VerticalAlignment="Center"/>

        <!-- Menu Placeholder (will be filled by content) -->
        <ContentPresenter Grid.Column="1" 
                         x:Name="MenuContentPresenter"
                         VerticalAlignment="Center"
                         Content="{Binding ChromeMenuContent, RelativeSource={RelativeSource AncestorType=local:CustomWindowChrome}}"/>

        <!-- Title -->
        <TextBlock Grid.Column="3"
                   x:Name="TitleText"
                   Text="{Binding WindowTitle, RelativeSource={RelativeSource AncestorType=local:CustomWindowChrome}}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="White"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>

        <!-- Window Control Buttons -->
        <StackPanel Grid.Column="5" 
                   Orientation="Horizontal"
                   HorizontalAlignment="Right">
            
            <!-- Minimize Button -->
            <Button x:Name="MinimizeButton"
                    Width="30"
                    Height="30"
                    Content="─"
                    ToolTip="Minimize">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="Transparent"
                                BorderThickness="0">
                            <TextBlock Text="{TemplateBinding Content}"
                                      Foreground="White"
                                      FontSize="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Bottom"
                                      Margin="0,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E5266"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C2833"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Maximize/Restore Button -->
            <Button x:Name="MaximizeButton"
                    Width="30"
                    Height="30"
                    Content="□"
                    ToolTip="Maximize">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="Transparent"
                                BorderThickness="0">
                            <TextBlock Text="{TemplateBinding Content}"
                                      Foreground="White"
                                      FontSize="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Bottom"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E5266"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C2833"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Close Button -->
            <Button x:Name="CloseButton"
                    Width="30"
                    Height="30"
                    Content="✕"
                    ToolTip="Close">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="Transparent"
                                BorderThickness="0">
                            <TextBlock Text="{TemplateBinding Content}"
                                      Foreground="White"
                                      FontSize="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Bottom"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
