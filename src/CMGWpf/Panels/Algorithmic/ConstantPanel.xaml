<UserControl x:Class="CMGWpf.Panels.Algorithmic.ConstantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:model="clr-namespace:CMGWpf.Model"
             d:DataContext="{d:DesignInstance Type=model:Constant}"
             xmlns:local="clr-namespace:CMGWpf.Panels.Algorithmic"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
            <Label Content="Value"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1">
            <xctk:DoubleUpDown 
                FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="{Binding FormattedValue, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
    </Grid>
</UserControl>
