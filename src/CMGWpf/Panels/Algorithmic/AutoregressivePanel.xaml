<UserControl x:Class="CMGWpf.Panels.Algorithmic.AutoregressivePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels.Algorithmic"
             xmlns:model="clr-namespace:CMGWpf.Model"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             d:DataContext="{d:DesignInstance Type=model:Autoregressive}"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
            <Label Content="Seed"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0">
            <Label Content="Initial Value"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="0">
            <Label Content="Alpha"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="0">
            <Label Content="Dispersion"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="0">
            <Label Content="Lo"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="5" Grid.Row="0">
            <Label Content="Hi"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1">
            <Button Content="New Seed" Background="Green" Foreground="White"
                    Command="{Binding DataContext.AutoregressiveSeedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"/>
            <TextBox Text="{Binding Seed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1">
            <xctk:DoubleUpDown
                FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Initial, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="{Binding FormattedInitial, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="1">
            <xctk:DoubleUpDown 
                FormatString="F3"
                Value="{Binding Alpha, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="0" 
                Maximum="1" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="(0-1)"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="1">
            <xctk:DoubleUpDown 
                FormatString="F3"
                Value="{Binding Sigma, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="0" 
                Maximum="10000" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="(>0)"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="1">
            <xctk:DoubleUpDown
                FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Lo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="{Binding FormattedLo, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="5" Grid.Row="1">
            <xctk:DoubleUpDown
                FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Hi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="{Binding FormattedHi, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
    </Grid>
</UserControl>
