<UserControl x:Class="CMGWpf.Panels.Algorithmic.MarkovianPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels.Algorithmic"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:model="clr-namespace:CMGWpf.Model"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             d:DataContext="{d:DesignInstance Type=model:Markovian}"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="700">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
                    <Label Content="Seed"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0">
                    <Label Content="Start"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="0">
                    <Label Content="Lo"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="0">
                    <Label Content="Hi"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="0">
                    <Label Content="Step"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1">
                    <Button Content="New Seed" 
                            Command="{Binding DataContext.MarkovianSeedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"/>
                    <TextBox TextWrapping="NoWrap" Text="{Binding Seed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1">
                    <xctk:DoubleUpDown HorizontalAlignment="Left"
                        FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Value="{Binding Start, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <Label Content="{Binding FormattedStart, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="1">
                    <xctk:DoubleUpDown 
                        FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Value="{Binding Lo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <Label Content="{Binding FormattedLo, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="1">
                    <xctk:DoubleUpDown
                        FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Value="{Binding Hi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <Label Content="{Binding FormattedHi, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="1">
                    <xctk:DoubleUpDown 
                        FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Value="{Binding Step, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                        Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </StackPanel>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Content="From/To" Grid.Column="0" Grid.Row="0"/>
                <Label Content="Same" Grid.Column="1" Grid.Row="0"/>
                <Label Content="Up" Grid.Column="2" Grid.Row="0"/>
                <Label Content="Down" Grid.Column="3" Grid.Row="0"/>
                <Label Content="Same" Grid.Column="0" Grid.Row="1"/>
                <xctk:DoubleUpDown Grid.Column="1" Grid.Row="1"
                    Value="{Binding TransitionRows[0].Values[0], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0"
                    Maximum="1"
                    Increment=".01"
                                   FormatString="F2"
                                   />
                <xctk:DoubleUpDown Grid.Column="2" Grid.Row="1"
                    Value="{Binding TransitionRows[0].Values[1], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0" Maximum="1" Increment=".01"/>
                <xctk:DoubleUpDown Grid.Column="3" Grid.Row="1"
                    Value="{Binding TransitionRows[0].Values[2], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0" 
                    Maximum="1"
                    Increment=".01"                                   FormatString="F2"
/>
                <Label Content="Up" Margin="5" Grid.Column="0" Grid.Row="2"/>
                <xctk:DoubleUpDown Grid.Column="1" Grid.Row="2"
                    Value="{Binding TransitionRows[1].Values[0], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0"
                    Maximum="1"
                    Increment=".01"                                   FormatString="F2"
/>
                <xctk:DoubleUpDown Grid.Column="2" Grid.Row="2"
                    Value="{Binding TransitionRows[1].Values[1], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0" 
                    Maximum="1" 
                    Increment=".01"                                   FormatString="F2"
/>
                <xctk:DoubleUpDown Grid.Column="3" Grid.Row="2"
                    Value="{Binding TransitionRows[1].Values[2], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0"
                    Maximum="1"
                    Increment=".01"                                   FormatString="F2"
/>
                <Label Content="Down" Margin="5" Grid.Column="0" Grid.Row="3"/>
                <xctk:DoubleUpDown Grid.Column="1" Grid.Row="3"
                    Value="{Binding TransitionRows[2].Values[0], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0"
                    Maximum="1"
                    Increment=".01"                                   FormatString="F2"
/>
                <xctk:DoubleUpDown Grid.Column="2" Grid.Row="3"
                    Value="{Binding TransitionRows[2].Values[1], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0" 
                    Maximum="1" 
                    Increment=".01"                                   FormatString="F2"
/>
                <xctk:DoubleUpDown Grid.Column="3" Grid.Row="3"
                    Value="{Binding TransitionRows[2].Values[2], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="0"
                    Maximum="1"
                    Increment=".01"                                   FormatString="F2"
/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
