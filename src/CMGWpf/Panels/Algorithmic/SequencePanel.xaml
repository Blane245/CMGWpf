<UserControl x:Class="CMGWpf.Panels.Algorithmic.SequencePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels.Algorithmic"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:model="clr-namespace:CMGWpf.Model"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             d:DataContext="{d:DesignInstance Type=model:Sequence}"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800"
             >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
            <Label Content="Sequence Name"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0">
            <Label Content="Transposition"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="0">
            <Label Content="Reverse?"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="0">
            <Label Content="Reflect?"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="0">
            <Label Content="Reflect Pitch"/>
            <Label Content="{Binding FormattedReflectPitch, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="5,0,0,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1">
            <Button Content="Reload Sequences" Command="{Binding DataContext.ReloadSequencesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="Green" Foreground="White"/>
            <ComboBox ItemsSource="{Binding DataContext.NoteSequenceNames, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0"/>
            <Button Content="View Sequence" Command="{Binding DataContext.ViewSequenceCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding }" Background="Green" Foreground="White"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1">
            <xctk:DoubleUpDown Value="{Binding Transpose, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}" FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="1">
            <CheckBox IsChecked="{Binding ReverseSequence, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="1">
            <CheckBox IsChecked="{Binding ReflectSequence, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="1">
            <xctk:DoubleUpDown Value="{Binding ReflectPitch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}" FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
    </Grid>
</UserControl>
