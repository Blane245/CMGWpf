<UserControl x:Class="CMGWpf.Panels.Tools.GeneratorsStaggerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                     xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
            xmlns:local="clr-namespace:CMGWpf.Panels.Tools"
                     xmlns:viewmodel="clr-namespace:CMGWpf.View"
                     d:DataContext="{d:DesignInstance Type=viewmodel:ToolsViewModel.Instance}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <DataTemplate x:Key="Select">
            <StackPanel Orientation="Horizontal">
                <CheckBox IsChecked="{Binding Path=IsSelected}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="Up">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="MoveUp" Command="{Binding DataContext.MoveStaggerUp, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                    <materialIcons:MaterialIcon Kind="ArrowUp"/>
                </Button>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="Down">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="MoveDown" Command="{Binding DataContext.MoveStaggerDown, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                    <materialIcons:MaterialIcon Kind="ArrowDown"/>
                </Button>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <StackPanel Orientation="Vertical">
        <Label Content="Stagger Generators Start Time" FontSize="16"/>
        <StackPanel Orientation="Horizontal">
            <Label Content="Primary Generator: "/>
            <ComboBox ItemsSource="{Binding GeneratorList}" SelectedItem="{Binding PrimaryGeneratorName, Mode=TwoWay}" ToolTip="Select the generator that will be used to Stagger the start times for the secondary generators."/>
            <Label Content="Secondary Generators: "/>
            <ListView ItemsSource="{Binding StaggerGeneratorList}">
                <ListView.View>
                    <GridView ColumnHeaderToolTip="Stagger selected generators in arranged order">
                        <GridViewColumn CellTemplate="{StaticResource Up}" Header="Up"/>
                        <GridViewColumn CellTemplate="{StaticResource Down}" Header="Down"/>
                        <GridViewColumn CellTemplate="{StaticResource Select}" Header="Select"/>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=TrackName}" Header="Track"/>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=GeneratorName}" Header="Generator"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Button Width="50" Content="Stagger" Command="{Binding Stagger}" Margin="0"/>
        </StackPanel>
    </StackPanel>
</UserControl>
