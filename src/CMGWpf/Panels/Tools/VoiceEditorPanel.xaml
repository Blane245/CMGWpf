<UserControl x:Class="CMGWpf.Panels.VoiceEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:panels="clr-namespace:CMGWpf.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Vertical" Background="White">
        <Label Content="{Binding VoiceEditorTitle}" FontSize="16" HorizontalAlignment="Left"/>
        <StackPanel Orientation="Horizontal">
            <Label Content="Name: "/>
            <TextBox Text="{Binding NewVoiceName}" ToolTip="Enter a new unique name for the voice" MinWidth="200"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Description: "/>
            <TextBox Text="{Binding UIVoice.Description}" ToolTip="Enter a description for the voice" MinWidth="200"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Timbre: "/>
            <ComboBox ItemsSource="{Binding TimbreOptions}" SelectedValue="{Binding UIVoice.Timbre, Mode=TwoWay}" ToolTip="Select a timbre for the voice"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Duration (sec): "/>
            <xctk:SingleUpDown Value="{Binding UIVoice.Duration}" 
                               Minimum="0"
                               Maximum="100"
                               Increment="0.1"
                               FormatString="F3"
                               ToolTip="Enter the duration for the voice in seconds. Zero means full length."/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Register Lo (0-127): "/>
            <xctk:SingleUpDown Value="{Binding UIVoice.RegisterLo}" 
                               Minimum="0"
                               Maximum="127"
                               Increment="1"
                               ToolTip="Enter the lowest MIDI note for the voice"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Register Hi (0-127): "/>
            <xctk:SingleUpDown Value="{Binding UIVoice.RegisterHi}" 
                               Minimum="0"
                               Maximum="127"
                               Increment="1"
                               ToolTip="Enter the highest MIDI note for the voice"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="SoundFont File: "/>
            <ComboBox ItemsSource="{Binding SoundFontFileNames}" SelectedValue="{Binding NewSoundFontFile, Mode=TwoWay}" ToolTip="Select a SoundFont file for the voice"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="Preset: "/>
            <ComboBox ItemsSource="{Binding PresetNames}" SelectedValue="{Binding UIVoice.PresetName, Mode=TwoWay}" ToolTip="Select a preset from the selected SoundFont file for the voice"/>
        </StackPanel>
        <Border BorderBrush="LightGray" BorderThickness="1"></Border>
        <StackPanel Orientation="Horizontal">
            <Button Command="{Binding SubmitVoiceCommand}" Content="Submit" ToolTip="Submit the ensemble changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
            <Button Command="{Binding CancelEditorCommand}" Content="Cancel" ToolTip="Cancel ensemble changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
        </StackPanel>
    </StackPanel>
</UserControl>
