<UserControl x:Class="CMGWpf.Panels.NoteSequenceEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels"
             xmlns:panels="clr-namespace:CMGWpf.Panels"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" MinHeight="800"
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- This panel, which appears in the note sequence panel, contains the properties of a note sequence when one is selected. All properties may be modified including the name, tag list, and sequence items. Tag list is a comma-delimited string, which is validated against the current DB Tags and updated in the notesequence_tag table. The sequence items are decoded from the Items property, managed by a data grid and, then encoded back to the Items property are modified data grids. 
    -->
    <Grid>
        <Grid.Resources>
            <DataTemplate x:Key="FloatTemplate">
                <xctk:SingleUpDown Value="{Binding Path=Beats, Mode=TwoWay}" 
                                   Minimum="0"
                                   Maximum="100"
                                   Increment="0.03125"
                                   ToolTip="Enter the number of beats for the note (32nds)"/>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Content="{Binding NoteSequenceEditorTitle}" FontSize="16"/>
        <StackPanel Orientation="Vertical" Grid.Row="1">
            <StackPanel Orientation="Horizontal">
                <Label Content="Name: "/>
                <TextBox Text="{Binding NewNoteSequenceName}" ToolTip="Enter the name of the note sequence" MinWidth="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Tags: "/>
                <TextBox Text="{Binding NewTagListString}" ToolTip="Enter the tags for the note sequence, separated by commas" MinWidth="200"/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <Label Content="Notes in Sequence" VerticalAlignment="Top"/>
                    <DataGrid ItemsSource="{Binding NewNoteItems}" AutoGenerateColumns="False" 
                          CanUserDeleteRows="True"
                          CanUserAddRows="True"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          CanUserReorderColumns="False"
                              Width="Auto"
                              MaxHeight="400"
                          >
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Note" Binding="{Binding Path=Note, Mode=TwoWay}" MinWidth="100"/>
                            <DataGridTemplateColumn Header="Beats" MinWidth="100" CellTemplate="{StaticResource FloatTemplate}"  CellEditingTemplate="{StaticResource FloatTemplate}"/>
                        </DataGrid.Columns>
                    </DataGrid>
            </StackPanel>
            <Border BorderBrush="LightGray" BorderThickness="1"></Border>
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SubmitNoteSequenceCommand}" Content="Submit" ToolTip="Submit the note sequence changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
                <Button Command="{Binding CancelEditorCommand}" Content="Cancel" ToolTip="Cancel note sequence changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
            </StackPanel>
            <Border BorderBrush="LightGray" BorderThickness="1"></Border>
        </StackPanel>
        <panels:MessagePanel Grid.Row="2" Source="{Binding DataContext.Errors, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="0,5,0,5" MinHeight="150"/>
    </Grid>
</UserControl>
