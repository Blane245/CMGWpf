<UserControl x:Class="CMGWpf.Panels.Tools.TagEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels.Tools"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:panels="clr-namespace:CMGWpf.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Orientation="Vertical" Background="White">
            <Label Content="{Binding TagEditorTitle}" FontSize="16" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal">
                <Label Content="Name: "/>
                <TextBox Text="{Binding NewTagName}" ToolTip="Enter a new unique name for the voice" MinWidth="200"/>
            </StackPanel>
            <Border BorderBrush="LightGray" BorderThickness="1"></Border>
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SubmitTagCommand}" Content="Submit" ToolTip="Submit the ensemble changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
                <Button Command="{Binding CancelEditorCommand}" Content="Cancel" ToolTip="Cancel ensemble changes" Width="100"  Margin="5"  HorizontalAlignment="Left"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
