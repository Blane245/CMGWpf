<UserControl x:Class="CMGWpf.Panels.Tools.GeneratorsEqualPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels.Tools"
                     xmlns:viewmodel="clr-namespace:CMGWpf.View"
                     d:DataContext="{d:DesignInstance Type=viewmodel:ToolsViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Vertical">
        <Label Content="Set Generators Durations Equal" FontSize="16"/>
        <StackPanel Orientation="Horizontal">
            <Label Content="Primary Generator: "/>
            <ComboBox ItemsSource="{Binding GeneratorList}" SelectedItem="{Binding PrimaryGeneratorName, Mode=TwoWay}" ToolTip="Select the generator that will be used to determine the duration to be used."/>
            <Label Content="Secondary Generators: "/>
            <ListBox x:Name="SecondaryGeneratorsListBox"
                             ItemsSource="{Binding GeneratorList}" 
                             SelectionMode="Multiple" 
                             ToolTip="Select the generators whose durations will be set equal to the primary generator."/>
            <Label Content="Maintain Time? "/>
            <ComboBox ItemsSource="{Binding MaintainAlignTimeOptions}" SelectedItem="{Binding AlignTimeOption}" ToolTip="Select either the start or stop time for setting generation durations equal."/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Button Width="50" Content="Set Equal" Command="{Binding SetEqual}" Margin="0"/>
        </StackPanel>
    </StackPanel>
</UserControl>
