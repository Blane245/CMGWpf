<Window x:Class="CMGWpf.PlayFunctions.PlayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:local="clr-namespace:CMGWpf.PlayFunctions"
        xmlns:services="clr-namespace:CMGWpf.Services"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        d:DataContext="{d:DesignInstance Type=viewmodel:FileViewModel}"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        mc:Ignorable="d"
        Title="Play" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary Source="/Styles/PlayDialogStyles.xaml"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding Source={x:Static services:SizeService.Instance}, Path=MenuHeight}"/>
            <RowDefinition Height="{Binding Source={x:Static services:SizeService.Instance}, Path=MenuHeight}"/>
            <RowDefinition Height="{Binding Source={x:Static services:SizeService.Instance}, Path=BodyHeight}"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="Bisque">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40px"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0"
                Source="pack://application:,,,/Assets/CGM2.png" 
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="20" 
                MaxHeight="20" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Label Content="Audio/Roll Play for File:"/>
                <Label Content="{Binding FileName}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="_" x:Name="BtnMinimize" Style="{StaticResource WindowButton}" Click="BtnMinimize_Click"/>
                <Button Content="⬜" x:Name="BtnMaximize"  Style="{StaticResource WindowButton}" Click="BtnMaximize_Click"/>
                <Button Content="X" x:Name="BtnClose"  Style="{StaticResource WindowButton}" Click="BtnClose_Click"/>
            </StackPanel>

        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Content="{materialIcons:MaterialIconExt Kind=Restart}" Command="{Binding RewindCommand}" Margin="5"/>
            <Button Command="{Binding PlayPauseCommand}" Margin="5">
                <materialIcons:MaterialIcon x:Name="SoloIcon">
                    <materialIcons:MaterialIcon.Style>
                        <Style TargetType="materialIcons:MaterialIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Kind" Value="Pause"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                    <Setter Property="Kind" Value="Play"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialIcons:MaterialIcon.Style>
                </materialIcons:MaterialIcon>
            </Button>
            <StackPanel>
                <TextBox Text="Volume" Margin="0" HorizontalAlignment="Center"/>
                <Slider
                Width="200"
                Minimum="-10"
                Maximum="10"
                Value="{Binding AudioVolume, Mode=TwoWay}"
                TickFrequency="1"
                TickPlacement="TopLeft"
                IsSnapToTickEnabled="True"
                Margin="5"
                VerticalAlignment="Center"
            />
            </StackPanel>
            <StackPanel>
                <TextBox Text="Position" Width="50" Margin="0" HorizontalAlignment="Center"/>
                <Slider 
                    Width="200" 
                    Minimum="0" 
                    Maximum="{Binding PlayDuration}" 
                    Value="{Binding CurrentPlayPosition, Mode=TwoWay}" 
                    Margin="5"
                    VerticalAlignment="Center"
                    />
            </StackPanel>
            <Label Content="{Binding CurrentPlayTime}" Width="50"/>
            <Button Content="{materialIcons:MaterialIconExt Kind=AudioBook}" Command="{Binding ShowVoicesCommand}" Margin="5"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Margin="5">
                <Grid Width="100" Margin="0">
                    <Line X1="0" Y1="15" X2="{Binding SignalLevelPixels[0]}" Y2="15" Stroke="Red" StrokeThickness="1" />
                    <Line X1="{Binding MaxSignalLevelPixels[0]}" Y1="0" X2="{Binding MaxSignalLevelPixels[0]}" Y2="30" Stroke="Black" StrokeThickness="1" />
                </Grid>
            </Border>
            <Border BorderBrush="LightGray" BorderThickness="1" Margin="5">
                <Grid Width="100" Margin="0">
                    <Line X1="0" Y1="15" X2="{Binding SignalLevelPixels[1]}" Y2="15" Stroke="Red" StrokeThickness="1"/>
                    <Line X1="{Binding MaxSignalLevelPixels[1]}" Y1="0" X2="{Binding MaxSignalLevelPixels[1]}" Y2="30" Stroke="Black" StrokeThickness="1" />
                </Grid>
            </Border>
        </StackPanel>
        <Grid Grid.Row="2" Background="LightGray" Margin="10,0,0,0">
            <!-- Scrollable canvas layer - scrolling controlled programmatically -->
            <ScrollViewer x:Name="SoundRollScrollViewer"
                          HorizontalScrollBarVisibility="Hidden" 
                          VerticalScrollBarVisibility="Hidden">
                <Canvas x:Name="ScrollRollCanvas" 
                        Background="White"
                        Initialized="ScrollRollCanvas_Initialized"/>
            </ScrollViewer>

            <!-- Fixed overlay canvas (does not scroll) -->
            <Canvas x:Name="SoundRollFixedCanvas" 
                    Background="Transparent"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
