<Window x:Class="CMGWpf.PlayFunctions.PlayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:local="clr-namespace:CMGWpf.PlayFunctions"
        xmlns:panels="clr-namespace:CMGWpf.Panels"
        xmlns:services="clr-namespace:CMGWpf.Services"
        xmlns:viewmodel="clr-namespace:CMGWpf.View"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        d:DataContext="{d:DesignInstance Type=viewmodel:PlayViewModel}"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Title="Play" Height="450" Width="800"
        >
    <Window.Resources>
        <ResourceDictionary Source="/Styles/PlayDialogStyles.xaml"/>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                           ResizeBorderThickness="5"
                           GlassFrameThickness="0"
                           CornerRadius="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <panels:CustomWindowChrome Grid.Row="0"
                                     WindowTitle="{Binding PlayTitle}"
                                     ChromeBackground="SaddleBrown">
        </panels:CustomWindowChrome>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Content="{materialIcons:MaterialIconExt Kind=Restart}" Command="{Binding RewindCommand}" Margin="5"/>
            <Button Command="{Binding PlayPauseCommand}" Margin="5">
                <materialIcons:MaterialIcon x:Name="SoloIcon">
                    <materialIcons:MaterialIcon.Style>
                        <Style TargetType="materialIcons:MaterialIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Kind" Value="Pause"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                    <Setter Property="Kind" Value="Play"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialIcons:MaterialIcon.Style>
                </materialIcons:MaterialIcon>
            </Button>
            <StackPanel>
                <TextBlock Text="Volume" Margin="0" HorizontalAlignment="Center"/>
                <Slider
                Width="200"
                Minimum="-10"
                Maximum="10"
                Value="{Binding AudioVolume, Mode=TwoWay}"
                TickFrequency="1"
                TickPlacement="TopLeft"
                IsSnapToTickEnabled="True"
                Margin="5"
                VerticalAlignment="Center"
            />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Position" Width="50" Margin="0" HorizontalAlignment="Center"/>
                <Slider 
                    Width="200" 
                    Minimum="0" 
                    Maximum="{Binding PlayDuration}" 
                    Value="{Binding CurrentPlayPosition, Mode=TwoWay}" 
                    Margin="5"
                    VerticalAlignment="Center"
                    />
            </StackPanel>
            <Label Content="{Binding CurrentPlayTime}" Width="50"/>
            <Button Content="{materialIcons:MaterialIconExt Kind=AudioBook}" 
                    Command="{Binding ShowVoicesCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                    Margin="5"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Margin="5">
                <Grid Width="100" Margin="0">
                    <Line X1="0" Y1="15" X2="{Binding SignalLevelPixels[0]}" Y2="15" Stroke="Red" StrokeThickness="1" />
                    <Line X1="{Binding MaxSignalLevelPixels[0]}" Y1="0" X2="{Binding MaxSignalLevelPixels[0]}" Y2="30" Stroke="Black" StrokeThickness="1" />
                </Grid>
            </Border>
            <Border BorderBrush="LightGray" BorderThickness="1" Margin="5">
                <Grid Width="100" Margin="0">
                    <Line X1="0" Y1="15" X2="{Binding SignalLevelPixels[1]}" Y2="15" Stroke="Red" StrokeThickness="1"/>
                    <Line X1="{Binding MaxSignalLevelPixels[1]}" Y1="0" X2="{Binding MaxSignalLevelPixels[1]}" Y2="30" Stroke="Black" StrokeThickness="1" />
                </Grid>
            </Border>
        </StackPanel>
        <Grid Grid.Row="2" Background="LightGray" Margin="10,0,0,0">
            <ScrollViewer x:Name="SoundRollScrollViewer"
                          HorizontalScrollBarVisibility="Hidden" 
                          VerticalScrollBarVisibility="Hidden">
                <Canvas x:Name="SoundRollCanvas" 
                        Background="White"
                        Initialized="SoundRollCanvas_Initialized"/>
            </ScrollViewer>
            <Canvas x:Name="SoundRollFixedCanvas" 
                    Background="Transparent"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
