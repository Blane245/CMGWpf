<Window x:Class="CMGWpf.PlayFunctions.VideoProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:CMGWpf.Services"
        Title="Generating Video" 
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="{Binding Path=DisplayWidth, Source={x:Static services:GlobalService.Instance}}"
        Height="{Binding Path=DisplayHeight, Source={x:Static services:GlobalService.Instance}}"
        WindowStartupLocation="Manual">
    <!-- Semi-transparent black overlay to hide the scrolling underneath -->
    <Grid Background="Black">
        <Grid Width="450" 
              Height="180"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Background="#FF2D2D30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       x:Name="StatusText"
                       Text="Rendering frames..." 
                       FontSize="14"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>

            <ProgressBar Grid.Row="2" 
                         x:Name="ProgressBar"
                         Height="25" 
                         Width="350"
                         Minimum="0" 
                         Maximum="100" 
                         Value="0"/>

            <TextBlock Grid.Row="2" 
                       x:Name="ProgressText"
                       Text="0 / 0 frames"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"/>

            <Button Grid.Row="4" 
                    Content="Cancel" 
                    Width="100" 
                    Height="30"
                    Click="Cancel_Click"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20"/>
        </Grid>
    </Grid>
</Window>
