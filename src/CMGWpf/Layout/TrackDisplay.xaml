<UserControl x:Class="CMGWpf.Layout.TrackDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:model="clr-namespace:CMGWpf.Model"
             xmlns:services="clr-namespace:CMGWpf.Services"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             d:DataContext="{d:DesignInstance Type=viewmodel:TrackViewModel}"
             xmlns:local="clr-namespace:CMGWpf.Layout"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <Canvas Background="Transparent" ClipToBounds="True"            >
        <!-- ItemsControl to render generators from Track.Generators collection -->
        <ItemsControl ItemsSource="{Binding Generators}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Background="Transparent"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- Position each generator on the canvas -->
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding StartOffset}"/>
                    <Setter Property="Canvas.Top" Value="{Binding VerticalOffset}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <!-- Define how each generator is displayed -->
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding BackgroundColor}" 
                            Width="{Binding Width}"
                            Height="{Binding Height}"
                            BorderBrush="Black" 
                            BorderThickness="1"
                            CornerRadius="2"
                            Cursor="Hand"
                            Loaded="GeneratorBorder_Loaded">

                        <!-- Right-click context menu -->
                        <Border.ContextMenu>
                            <ContextMenu Padding="0">
                                <MenuItem Header="Edit..." Command="{Binding EditCommand}"/>
                                <MenuItem Header="Copy to Track..." Command="{Binding CopyCommand}"/>
                                <MenuItem Header="Move to Track..." Command="{Binding MoveCommand}"/>
                                <MenuItem Header="Mute" Command="{Binding MuteCommand}" IsCheckable="True" IsChecked="{Binding Generator.Mute}"/>
                                <MenuItem Header="Play..." Command="{Binding PlayCommand}"/>
                                <Separator/>
                                <MenuItem Header="Delete" Command="{Binding DeleteCommand}"/>
                            </ContextMenu>
                        </Border.ContextMenu>

                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <!-- Hide context menu when dragging -->
                                    <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                        <Setter Property="ContextMenu" Value="{x:Null}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <!-- Generator name -->
                        <TextBlock Text="{Binding Generator.Name}" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center"
                                   Foreground="Black"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Canvas>
</UserControl>
