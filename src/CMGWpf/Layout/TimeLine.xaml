<UserControl x:Class="CMGWpf.Layout.TimeLine"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Layout"
             xmlns:viewmodel="clr-namespace:CMGWpf.View" 
             xmlns:services="clr-namespace:CMGWpf.Services"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DataContext="{d:DesignInstance Type=viewmodel:TimeLineViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding Source={x:Static services:SizeService.Instance}, Path=ControlWidth}"/>
            <ColumnDefinition Width="{Binding Source={x:Static services:SizeService.Instance}, Path=DisplayWidth}"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding Source={x:Static services:SizeService.Instance}, Path=TimeLineHeight}"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="0">
            <Button 
            Margin="10,0,0,0"
            Foreground="Blue"
            Command="{Binding ZoomInCommand}"
            >
                <materialIcons:MaterialIcon Kind="Plus"/>
            </Button>
            <Button 
            Margin="10,0,0,0"
            Foreground="Blue"
            Command="{Binding ZoomOutCommand}"
            >
                <materialIcons:MaterialIcon Kind="Minus"/>
            </Button>
            <Button 
            Margin="10,0,0,0"
            Foreground="Blue"
            Command="{Binding PanLeftCommand}"
            >
                <materialIcons:MaterialIcon Kind="ArrowLeft"/>
            </Button>
            <Button 
            Margin="10,0,0,0"
            Foreground="Blue"
            Command="{Binding PanRightCommand}"
            >
                <materialIcons:MaterialIcon Kind="ArrowRight"/>
            </Button>
        </StackPanel>
        <Canvas 
        Grid.Column="1"
        Background="White" 
        Name="TimeLineCanvas" 
        Focusable="True"
        Loaded="TimeLineDisplay_Loaded">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseEnter">
                    <i:InvokeCommandAction Command="{Binding MouseEnterCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="MouseLeftButtonDown">
                    <i:InvokeCommandAction Command="{Binding MouseLeftButtonDownCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="MouseMove">
                    <i:InvokeCommandAction Command="{Binding MouseMoveCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="MouseLeave">
                    <i:InvokeCommandAction Command="{Binding MouseLeaveCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="MouseLeftButtonUp">
                    <i:InvokeCommandAction Command="{Binding MouseLeftButtonUpCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Canvas>
    </Grid>
</UserControl>
