<UserControl x:Class="CMGWpf.Layout.Footer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Layout"
             xmlns:services="clr-namespace:CMGWpf.Services" 
             xmlns:panels="clr-namespace:CMGWpf.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="800">
    <Grid Background="LightGray">
        <panels:MessageBox Source="{Binding DataContext.StatusMessages, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Grid>
</UserControl>
