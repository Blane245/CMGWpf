<UserControl x:Class="CMGWpf.Layout.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Layout"
             xmlns:services="clr-namespace:CMGWpf.Services"
             xmlns:viewmodel="clr-namespace:CMGWpf.View" 
             d:DataContext="{d:DesignInstance Type=viewmodel:FileViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="25" d:DesignWidth="800"
             >
    <Grid MouseDown="Grid_MouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40px"/>
            <ColumnDefinition Width="200px"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <Image 
                Source="pack://application:,,,/Assets/cmg-256.png" 
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="20" 
                MaxHeight="20" />
        </StackPanel>
        <StackPanel Grid.Column="1">
            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="_New..." Command="{Binding FileNewCommand}"/>
                    <MenuItem Header="_Open..." Command="{Binding FileOpenCommand}"/>
                    <MenuItem Header="_Save" Command="{Binding FileSaveCommand}"/>
                    <MenuItem Header="Save _As..." Command="{Binding FileSaveAsCommand}"/>
                    <MenuItem Header="_Recent" ItemsSource="{Binding RecentFiles}">
                        <MenuItem.ItemTemplate>
                            <DataTemplate>
                                <MenuItem Header="{Binding}" Command="{Binding DataContext.FileOpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </MenuItem.ItemTemplate>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="E_xit" Command="{Binding ExitFileCommand}"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Add Track..." Command="{Binding AddTrackCommand}"/>
                    <MenuItem Header="_Comment..." Command="{Binding EditCommentCommand}"/>
                    <MenuItem Header="_Preferences..." Command="{Binding GlobalServices.EditPreferencesCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </MenuItem>
                <MenuItem Header="_Tools">
                    <MenuItem Header="Midi/Frequency Converter..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=MidiFrequencyConverterCommand}"/>
                    <MenuItem Header="Start CMG Database Editor" Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=StartCMGDBEditorCommand}"/>
                    <MenuItem Header="Measure Duration Calculator..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=MeasureDurationCalculatorCommand}"/>
                    <MenuItem Header="Oscillator Frequency Calculator..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=OscillatorFrequencyCalculatorCommand}"/>
                    <MenuItem Header="Set Generators Duration Equal..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=SetGeneratorsDurationEqualCommand}"/>
                    <MenuItem Header="Stagger Generators Start Time..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=StaggerGeneratorsStartTimeCommand}"/>
                    <MenuItem Header="Align Generator..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=AlignGeneratorsCommand}"/>
                </MenuItem>
                <MenuItem Header="_Play">
                    <MenuItem Header="_Play..." Command="{Binding PlayViewModel.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <MenuItem Header="_Report..." Command="{Binding PlayViewModel.RecordCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </MenuItem>
            </Menu>
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding WindowTitle}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>

        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="_" x:Name="BtnMinimize" Style="{StaticResource WindowButton}"
                    Click="BtnMinimize_Click"
                    />
            <Button Content="⬜" x:Name="BtnMaximize"  Style="{StaticResource WindowButton}"
                    Click="BtnMaximize_Click"
                    />
            <Button Content="X" x:Name="BtnClose"  Style="{StaticResource WindowButton}"
                    Click="BtnClose_Click"
                    />
        </StackPanel>
    </Grid>
</UserControl>
