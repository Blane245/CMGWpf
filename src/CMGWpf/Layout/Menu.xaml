<UserControl x:Class="CMGWpf.Layout.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Layout"
             xmlns:services="clr-namespace:CMGWpf.Services"
             xmlns:viewmodel="clr-namespace:CMGWpf.View" 
             d:DataContext="{d:DesignInstance Type=viewmodel:FileViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="25" d:DesignWidth="800"
             >
    <Grid MouseDown="Grid_MouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40px"/>
            <ColumnDefinition Width="200px"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <Image 
                Source="pack://application:,,,/Assets/cmg-256.png" 
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="20" 
                MaxHeight="20" />
        </StackPanel>
        <StackPanel Grid.Column="1">
            <Menu>
                <MenuItem Header="_File" ToolTip="Perform a CMG file operation.">
                    <MenuItem Header="_New..." Command="{Binding FileNewCommand}" InputGestureText="Ctrl+N" ToolTip="Create a blank CMG file."/>
                    <MenuItem Header="_Open..." Command="{Binding FileOpenCommand}" InputGestureText="Ctrl+O" ToolTip="Open an existing CMG file."/>
                    <MenuItem Header="_Save" Command="{Binding FileSaveCommand}" InputGestureText="Ctrl+S" ToolTip="Save the currently open CMG file."/>
                    <MenuItem Header="Save _As..." Command="{Binding FileSaveAsCommand}" InputGestureText="Ctrl+A" ToolTip="Save the currently opened CMG file and another CMG file."/>
                    <MenuItem Header="_Recent" ItemsSource="{Binding RecentFiles}" InputGestureText="Ctrl+R" ToolTip="Open a recently edited CMG file.">
                        <!-- TODO Add Ctrl+n to the input gesture text for each item in the list, from 0 to 9-->
                        <MenuItem.ItemTemplate>
                            <DataTemplate>
                                <MenuItem Header="{Binding}" Command="{Binding DataContext.FileOpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </MenuItem.ItemTemplate>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="E_xit" Command="{Binding ExitFileCommand}"/>
                </MenuItem>
                <MenuItem Header="_Edit" ToolTip="Perform a application or file level edit operation.">
                    <MenuItem Header="_Add Track" Command="{Binding AddTrackCommand}" InputGestureText="Ctrl+T" ToolTip="Add a new track to the CMG file."/>
                    <MenuItem Header="_Comment..." Command="{Binding EditCommentCommand}" ToolTip="Edit a CMG file comment." InputGestureText="Ctrl+Shift+C"/>
                    <MenuItem Header="_Preferences..." Command="{Binding GlobalServices.EditPreferencesCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Edit CMG preferences." InputGestureText="Ctrl+P"/>
                </MenuItem>
                <MenuItem Header="_Tools" ToolTip="Access CMG tools.">
                    <MenuItem Header="_Midi/Frequency Converter..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=MidiFrequencyConverterCommand}"
                              ToolTip="Convert between midi number and audio frequency."
                              InputGestureText="Ctrl+M"
                              />
                    <MenuItem Header="Start CMG _Database Editor" Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=StartCMGDBEditorCommand}"
                              ToolTip="Start the CMG Database Editor."
                        InputGestureText="Ctrl+D"                              
                              />
                    <MenuItem Header="_Measure Duration Calculator..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=MeasureDurationCalculatorCommand}"
                              ToolTip="Determine the number of seconds in a measure at a certain BPM."
                              InputGestureText="Ctrl+M"
                              />
                    <MenuItem Header="Oscillator _Frequency Calculator..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=OscillatorFrequencyCalculatorCommand}"
                              ToolTip="Determine the oscillator frequency needed to hit values of an attribute with a certian amplitude."
                              InputGestureText="Ctrl+F"
                              />
                    <MenuItem Header="Set Generators Duration _Equal..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=SetGeneratorsDurationEqualCommand}"
                              ToolTip="Set a collection of genrators to have the same duration."
                              InputGestureText="Ctrl+E"
                              />
                    <MenuItem Header="S_tagger Generators Start Time..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=StaggerGeneratorsStartTimeCommand}"
                              ToolTip="Stagger a collection of generators' start times."
                              InputGestureText="Ctrl+T"
                              />
                    <MenuItem Header="_Align Generator..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=AlignGeneratorsCommand}"
                              ToolTip="Align a collection of genrators start or stop times"
                              InputGestureText="Ctrl+A"
                              />
                </MenuItem>
                <MenuItem Header="_Play">
                    <MenuItem Header="_Play..." Command="{Binding PlayViewModel.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              ToolTip="Play the audio and view the scroll rool of the active generators."
                              InputGestureText="Ctrl+Shift+P"
                              />
                    <MenuItem Header="_Report..." Command="{Binding PlayViewModel.ReportCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              ToolTip="Generate an HTML report of the CMG file contents."
                              InputGestureText="Ctrl+Shift+R"
                              />
                </MenuItem>
            </Menu>
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding WindowTitle}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>

        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="_" x:Name="BtnMinimize" Style="{StaticResource WindowButton}"
                    Click="BtnMinimize_Click"
                    />
            <Button Content="⬜" x:Name="BtnMaximize"  Style="{StaticResource WindowButton}"
                    Click="BtnMaximize_Click"
                    />
            <Button Content="X" x:Name="BtnClose"  Style="{StaticResource WindowButton}"
                    Click="BtnClose_Click"
                    />
        </StackPanel>
    </Grid>
</UserControl>
