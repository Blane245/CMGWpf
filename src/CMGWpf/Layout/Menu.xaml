<UserControl x:Class="CMGWpf.Layout.Menu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Layout"
             xmlns:services="clr-namespace:CMGWpf.Services"
             xmlns:viewmodel="clr-namespace:CMGWpf.View" 
             d:DataContext="{d:DesignInstance Type=viewmodel:FileViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="600"
             Background="Transparent"
             >
    <Grid Background="Transparent">
        <Menu Background="Transparent" VerticalAlignment="Center">
            <MenuItem Header="_File" ToolTip="Perform a CMG file operation.">
                <MenuItem Header="_New..." Command="{Binding FileNewCommand}" InputGestureText="Ctrl+N" ToolTip="Create a blank CMG file."/>
                <MenuItem Header="_Open..." Command="{Binding FileOpenCommand}" InputGestureText="Ctrl+O" ToolTip="Open an existing CMG file."/>
                <MenuItem Header="_Save" Command="{Binding FileSaveCommand}" InputGestureText="Ctrl+S" ToolTip="Save the currently open CMG file."/>
                <MenuItem Header="Save _As..." Command="{Binding FileSaveAsCommand}" InputGestureText="Ctrl+A" ToolTip="Save the currently opened CMG file and another CMG file."/>
                <MenuItem Header="_Recent" ItemsSource="{Binding RecentFiles}" InputGestureText="Ctrl+0-9" ToolTip="Open a recently edited CMG file." AlternationCount="10">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}"/>
                            <Setter Property="Command" Value="{Binding DataContext.FileOpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                            <Setter Property="InputGestureText">
                                <Setter.Value>
                                    <MultiBinding StringFormat="Ctrl+{0}">
                                        <Binding Path="(ItemsControl.AlternationIndex)" RelativeSource="{RelativeSource Self}"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitFileCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit" ToolTip="Perform a application or file level edit operation.">
                <MenuItem Header="_Add Track" Command="{Binding AddTrackCommand}" InputGestureText="Ctrl+T" ToolTip="Add a new track to the CMG file."/>
                <MenuItem Header="_Comment..." Command="{Binding EditCommentCommand}" ToolTip="Edit a CMG file comment." InputGestureText="Ctrl+Shift+C"/>
                <MenuItem Header="_Preferences..." Command="{Binding Source={x:Static services:GlobalService.Instance}, Path=EditPreferencesCommand}" ToolTip="Edit CMG preferences." InputGestureText="Ctrl+P"/>
                </MenuItem>
            <MenuItem Header="_Tools" ToolTip="Access CMG tools.">
                <!-- 
                <MenuItem Header="Ensemble Voice Editor" Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=EnsembleVoiceEditorCommand}"
                              ToolTip="Display the Ensemble Voice Editor."
                        InputGestureText="Ctrl+E"                              
                              />
                <MenuItem Header="Note Sequence Editor" Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=NoteSequenceEditorCommand}"
                              ToolTip="Display the Note Sequence Editor."
                        InputGestureText="Ctrl+D"                              
                              />
                    -->
                <MenuItem Header="_Generator and Calculator Tools..." Command="{Binding Source={x:Static viewmodel:ToolsViewModel.Instance}, Path=GeneratorandCalculatorToolsCommand}"
                              ToolTip="Activate Generator and Calculator Tools Window"
                              InputGestureText="Ctrl+G"
                              />
            </MenuItem>
            <MenuItem Header="_Play">
                <MenuItem Header="_Play..." Command="{Binding PlayCommand}"
                              ToolTip="Play the audio and view the sound roll of the active generators."
                              InputGestureText="Ctrl+Shift+P"
                              />
                <MenuItem Header="_Report..." Command="{Binding ReportCommand}"
                              ToolTip="Generate an HTML report of the CMG file contents."
                              InputGestureText="Ctrl+Shift+R"
                              />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About CMG" Command="{Binding AboutCommand}"
                              ToolTip="Display a window showing information about this application"
                              />
                <MenuItem Header="User's Guide" Command="{Binding UGCommand}"
                              ToolTip="Open a browser tab to view the User's Guide"
                              />
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>
