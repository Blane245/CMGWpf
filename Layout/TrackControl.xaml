<UserControl x:Class="CMGWpf.Layout.TrackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Layout"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:services="clr-namespace:CMGWpf.Services"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             mc:Ignorable="d" 
             xmlns:model="clr-namespace:CMGWpf.Model"
             d:DataContext="{d:DesignInstance Type=viewmodel:TrackViewModel}"
             d:DesignHeight="150" d:DesignWidth="200">
    <Grid 
        Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Button x:Name="Delete" Grid.Row="0" Grid.Column="0" Command="{Binding DeleteCommand}">
            <materialIcons:MaterialIcon Kind="Delete"/>
        </Button>
        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Track.Name}" TextWrapping="Wrap"/>
        <Button x:Name="Rename" Grid.Row="0" Grid.Column="2" Command="{Binding RenameCommand}">
            <materialIcons:MaterialIcon Kind="Rename"/>
        </Button>
        <Button x:Name="Solo" Grid.Row="1" Grid.Column="0" Command="{Binding SoloCommand}">
            <materialIcons:MaterialIcon x:Name="SoloIcon">
                <materialIcons:MaterialIcon.Style>
                    <Style TargetType="materialIcons:MaterialIcon">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Track.Solo}" Value="True">
                                <Setter Property="Kind" Value="PersonCheck"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Track.Solo}" Value="False">
                                <Setter Property="Kind" Value="Person"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialIcons:MaterialIcon.Style>
            </materialIcons:MaterialIcon>
        </Button>
        <Menu
            Grid.Row="1" Grid.Column="1"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Margin="0,0,0,0"
        >
            <MenuItem Header="{materialIcons:MaterialIconExt Kind=MusicNoteQuarter, HorizontalAlignment=Center, IconSize=18}" HorizontalAlignment="Center" BorderBrush="Transparent">
                <MenuItem Header="Silent" Command="{Binding AddSilentCommand}"/>
                <MenuItem Header="Algorithmic" Command="{Binding AddAlgorithmicCommand}"/>
                <MenuItem Header="Stochastic" Command="{Binding AddStochasticCommand}"/>
            </MenuItem>
        </Menu>
        <Button x:Name="Mute" Grid.Row="1" Grid.Column="2" Command="{Binding MuteCommand}">
            <materialIcons:MaterialIcon x:Name="MuteIcon">
                <materialIcons:MaterialIcon.Style>
                    <Style TargetType="materialIcons:MaterialIcon">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Track.Mute}" Value="True">
                                <Setter Property="Kind" Value="VolumeOff"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Track.Mute}" Value="False">
                                <Setter Property="Kind" Value="VolumeHigh"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialIcons:MaterialIcon.Style>
            </materialIcons:MaterialIcon>
        </Button>
        <Button x:Name="ModeUp" Grid.Row="2" Grid.Column="0" Command="{Binding MoveUpCommand}">
            <materialIcons:MaterialIcon Kind="ArrowUp"/>
        </Button>
        <Menu
            Grid.Row="2" Grid.Column="1"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Margin="0,0,0,0"
        >
            <MenuItem Header="{materialIcons:MaterialIconExt Kind=Toolbox, HorizontalAlignment=Center, IconSize=18}" HorizontalAlignment="Center" BorderBrush="Transparent">
                <MenuItem Header="Duplicate" Command="{Binding NotImplementedCommand}"/>
                <MenuItem Header="Shift" Command="{Binding NotImplementedCommand}"/>
                <MenuItem Header="Volume" Command="{Binding NotImplementedCommand}"/>
            </MenuItem>
        </Menu>
        <Button x:Name="ModeDown" Grid.Row="2" Grid.Column="2" Command="{Binding MoveDownCommand}">
            <materialIcons:MaterialIcon Kind="ArrowDown"/>
        </Button>
    </Grid>
</UserControl>
