<UserControl x:Class="CMGWpf.Layout.Track"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Layout"
             xmlns:model="clr-namespace:CMGWpf.Model"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:services="clr-namespace:CMGWpf.Services"
             d:DataContext="{d:DesignInstance Type=model:Track}"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800">
    <Grid>
        <Border Grid.Column="0" Background="White" BorderBrush="Black" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Source={x:Static services:SizeService.Instance}, Path=ControlWidth.Value}"/>
                    <ColumnDefinition Width="{Binding Source={x:Static services:SizeService.Instance}, Path=DisplayWidth.Value}"/>
                </Grid.ColumnDefinitions>
                <local:TrackControl Grid.Column="0"/>
                <local:TrackDisplay Grid.Column="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
