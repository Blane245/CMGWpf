<UserControl x:Class="CMGWpf.Panels.Algorithmic.OscillatorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMGWpf.Panels.Algorithmic"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:model="clr-namespace:CMGWpf.Model"
             xmlns:viewmodel="clr-namespace:CMGWpf.View"
             d:DataContext="{d:DesignInstance Type=model:Oscillator}"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0">
            <Label Content="Modulator"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0">
            <Label Content="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="0">
            <Label Content="Frequency"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="0">
            <Label Content="Amplitude"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="0">
            <Label Content="Phase"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="1">
            <ComboBox ItemsSource="{x:Static viewmodel:GeneratorViewModel.ModulatorTypes}" SelectedItem="{Binding Modulator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsSynchronizedWithCurrentItem="True"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1">
            <xctk:DoubleUpDown 
                FormatString="{Binding ValueFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Center, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="{Binding FormattedCenter, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="1">
            <xctk:DoubleUpDown
                FormatString="F0"
                Value="{Binding Frequency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="0" 
                Maximum="100000" 
                Increment="1"/>
            <Label Content="mHz"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="1">
            <xctk:DoubleUpDown 
                FormatString="{Binding AmplitudeFormat, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Amplitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Increment="{Binding Increment, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Label Content="{Binding FormattedAmplitude, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="1">
            <xctk:DoubleUpDown 
                Value="{Binding Phase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Minimum="0" 
                Maximum="359" 
                Increment="1"/>
            <Label Content="degrees"/>
        </StackPanel>
    </Grid>
</UserControl>
